# Shared deployer private key used by every configured HTTP network.
# Must include 0x prefix and must have enough native test token on target chain.
CONTRACT_PRIVATE_KEY=

# Ethereum Sepolia
SEPOLIA_RPC_URL=

# Linea Sepolia
# Infura example: https://linea-sepolia.infura.io/v3/<PROJECT_ID>
LINEA_SEPOLIA_RPC_URL=

# Arc Testnet
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# Payment module admin addresses.
# PAYMENT_ADMIN defaults to deployer address when empty.
# PLATFORM_CONFIG_ADMIN defaults to PAYMENT_ADMIN when empty.
PAYMENT_ADMIN=
PLATFORM_CONFIG_ADMIN=

# Optional payment token override.
# If empty, scripts/payment/networkDefaults.ts preset will be used by chainId.
PAYMENT_USDC_ADDRESS=

# V2 Upgrade: existing PaymentRouter proxy address (for upgrade mode)
# If set, the script will upgrade the existing proxy instead of deploying new
EXISTING_PAYMENT_ROUTER_PROXY=

# Set to "true" to deploy PlatformConfig during fresh deployment
DEPLOY_PLATFORM_CONFIG=

# Target network for deploy-payment-v2.ts (default: arcTestnet)
DEPLOY_NETWORK=
